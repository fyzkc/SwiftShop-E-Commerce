
@{
    ViewData["Title"] = "ProductDetails";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<!-- Shop Detail Start -->
<div class="container-fluid pb-5">

    <!--Product Details Start-->
    <div class="row px-xl-5">

        <!--Product Images Start-->
        @await Component.InvokeAsync("ProductDetailImageSliderComponent")
        <!--Product Images End-->

        <!--Product Features Start-->
        @await Component.InvokeAsync("ProductDetailComponent")
        <!--Product Features End-->

    </div>
    <!--Product Details End-->

    <!--Product Informations Start-->
    <div class="row px-xl-5">
        <div class="col">
            <div class="bg-light p-30">
                <div class="nav nav-tabs mb-4">
                    <a class="nav-item nav-link text-dark active" data-toggle="tab" href="#tab-pane-1">Description</a>
                    <a class="nav-item nav-link text-dark" data-toggle="tab" href="#tab-pane-2">Information</a>
                    <a class="nav-item nav-link text-dark" data-toggle="tab" href="#tab-pane-3">Reviews (0)</a>
                </div>
                <div class="tab-content">

                    <!--Product Description-->
                    @await Component.InvokeAsync("ProductDetailDescriptionComponent")
                    
                    <!--Additional Information-->
                    @await Component.InvokeAsync("ProductDetailInformationComponent")

                    <!--Reviews-->
                    @await Component.InvokeAsync("ProductDetailReviewsComponent")
                </div>
            </div>
        </div>
    </div>
    <!--Product Informations End-->

</div>
<!-- Shop Detail End -->

