@model List<ResultCategoryDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>Kategoriler</h4>
                <div class="bs-example" data-example-id="bordered-table">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Kategori Adı</th>
                                <th>Görsel</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    @* <th scope="row">@item.CategoryId</th> *@
                                    <td>@item.CategoryName</td>
                                    <td>@item.ImageUrl</td>
                                    <td>
                                        <form asp-area="Admin" asp-controller="Category" asp-action="DeleteCategory" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.CategoryId" />
                                            <button type="submit" class="btn btn-danger" onclick="return confirm('Silmek istediğinizden emin misiniz?')">
                                                Sil
                                            </button>
                                        </form>
                                    </td>
                                    <td><a href="/Admin/Category/UpdateCategory/@item.CategoryId" class="btn btn-warning">Güncelle</a></td>
                                </tr>
                            }                            

                        </tbody>
                    </table>
                    <a href="/Admin/Category/CreateCategory" class="btn btn-primary">Kategori Ekle</a>
                </div>
            </div>
        </div>
    </div>
</section>

