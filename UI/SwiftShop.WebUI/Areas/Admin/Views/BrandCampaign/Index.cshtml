@model List<ResultBrandCampaignDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>Marka Kampanyaları</h4>
                <div class="bs-example" data-example-id="bordered-table">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Başlık</th>
                                <th>Alt Başlık</th>
                                <th>Görsel</th>
                                <th>Durum</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.SubTitle</td>
                                    <td>@item.ImageUrl</td>
                                    <td>
                                        @if (item.Status)
                                        {
                                            <span class="text-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger">Pasif</span>
                                        }

                                    </td>
                                    <td>
                                        <form asp-area="Admin" asp-controller="BrandCampaign" asp-action="DeleteBrandCampaign" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.BrandCampaignId" />
                                            <button type="submit" class="btn btn-danger" onclick="return confirm('Silmek istediğinizden emin misiniz?')">
                                                Sil
                                            </button>
                                        </form>
                                    </td>
                                    <td><a href="/Admin/BrandCampaign/UpdateBrandCampaign/@item.BrandCampaignId" class="btn btn-warning">Güncelle</a></td>
                                </tr>
                            }

                        </tbody>
                    </table>
                    <a href="/Admin/BrandCampaign/CreateBrandCampaign" class="btn btn-primary">Marka Kampanyası Ekle</a>
                </div>
            </div>
        </div>
    </div>
</section>
